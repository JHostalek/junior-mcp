{
  "name": "junior-mcp",
  "version": "0.1.0",
  "description": "MCP server for Junior — expose task queue, schedules, and hooks to Claude Code",
  "license": "MIT",
  "author": "Jan Hostalek",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JHostalek/junior-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/JHostalek/junior-mcp/issues"
  },
  "homepage": "https://github.com/JHostalek/junior-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "junior",
    "claude",
    "claude-code",
    "ai",
    "automation",
    "developer-tools"
  ],
  "type": "module",
  "bin": {
    "junior-mcp": "./dist/junior-mcp"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "build": "bun build src/index.ts --compile --outfile dist/junior-mcp",
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "bun run typecheck && bun run lint"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@types/node": "^22.13.4",
    "bun-types": "^1.3.9",
    "lefthook": "^2.1.1",
    "typescript": "^5.7.3"
  }
}
